<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SDRIQStreamer.App"
        xmlns:flex="clr-namespace:SDRIQStreamer.FlexRadio;assembly=SDRIQStreamer.FlexRadio"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="620"
        x:Class="SDRIQStreamer.App.MainWindow"
        x:DataType="local:MainWindowViewModel"
        x:Name="Root"
        Title="SDR-IQ-Streamer"
        Width="420" SizeToContent="Height"
        MinWidth="360" MinHeight="220">

    <Window.Styles>
        <Style Selector="FlyoutPresenter.compact-swatch-flyout">
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="MaxWidth" Value="106"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Window.Styles>

    <TabControl Margin="0">
        <TabControl.Styles>
            <Style Selector="TabItem">
                <Setter Property="Padding" Value="10,4"/>
            </Style>
            <Style Selector="Button">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </TabControl.Styles>
        <TabItem>
            <TabItem.Header>
                <TextBlock Text="Operating" FontSize="10" FontWeight="SemiBold"/>
            </TabItem.Header>
            <StackPanel Margin="8" Spacing="4">
                    <TextBlock Text="SDR-IQ-Streamer"
                               FontSize="15" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="{Binding ConnectionStatus}"
                               FontSize="12" Foreground="Green"
                               IsVisible="{Binding IsConnected}"/>

                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" Foreground="Gray"
                               IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Text="Available Radio / Station Targets" FontSize="11" Foreground="Gray"/>
                        <Button Grid.Column="1"
                                Content="Connect"
                                MinWidth="56"
                                Height="20"
                                FontSize="10"
                                Padding="8,0"
                                Command="{Binding ConnectCommand}"
                                IsVisible="{Binding !IsConnected}"/>
                        <Button Grid.Column="1"
                                Content="Disconnect"
                                MinWidth="56"
                                Height="20"
                                FontSize="10"
                                Padding="8,0"
                                Command="{Binding DisconnectCommand}"
                                IsVisible="{Binding IsConnected}"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding ConnectTargets}"
                             SelectedItem="{Binding SelectedConnectTarget}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local:RadioConnectTarget">
                                <TextBlock Text="{Binding DisplayLabel}" FontSize="12" Padding="2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ItemsControl ItemsSource="{Binding VisibleClientGroups}"
                                  IsVisible="{Binding IsConnected}"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ClientGroup">
                                <StackPanel Spacing="4" Margin="0,4,0,0">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0"
                                                   FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="Station:  {0}">
                                                    <Binding Path="Station"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="11"
                                                   Foreground="Green"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding #Root.((local:MainWindowViewModel)DataContext).DaxStreamingSummary}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding Panadapters}" Margin="8,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:PanSliceGroup">
                                                <Border BorderBrush="#E3E6EA" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,2,0,2">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding StreamSummary}"
                                                                   FontSize="11"
                                                                   Foreground="DarkCyan"
                                                                   VerticalAlignment="Center"/>

                                                        <ItemsControl ItemsSource="{Binding Slices}" Margin="8,1,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:SliceViewModel">
                                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                                               FontSize="11"
                                                                               VerticalAlignment="Center"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding StreamRequestStatus}"
                               FontSize="11" Foreground="DarkOrange"
                               IsVisible="{Binding StreamRequestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Margin="0,2,0,0"/>

                    <Separator Margin="0,8,0,4" Background="#DDD"/>
                    <TextBlock Text="CW Skimmer" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>

                    <ItemsControl ItemsSource="{Binding DaxIQStreams}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="flex:DaxIQStreamInfo">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6" Margin="0,1,0,1">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SkimmerRowLabel}"
                                               FontSize="11"
                                               Foreground="DarkCyan"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="Launch"
                                            MinWidth="56"
                                            Height="20"
                                            FontSize="10"
                                            Padding="8,0"
                                            Command="{Binding #Root.((local:MainWindowViewModel)DataContext).LaunchCwSkimmerForChannelCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding !IsSkimmerRunning}"/>
                                    <Button Grid.Column="1"
                                            Content="Stop"
                                            MinWidth="56"
                                            Height="20"
                                            FontSize="10"
                                            Padding="8,0"
                                            Command="{Binding #Root.((local:MainWindowViewModel)DataContext).StopCwSkimmerForChannelCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding IsSkimmerRunning}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,6,0,2" Background="#DDD"/>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,0,0,1">
                        <TextBlock Grid.Column="0" Text="Event" FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LatestFooterEvent}"
                                   FontSize="10"
                                   Foreground="DarkOrange"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </Grid>

            </StackPanel>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <TextBlock Text="Config" FontSize="10" FontWeight="SemiBold"/>
            </TabItem.Header>
            <DockPanel Margin="8" LastChildFill="True">
                    <DockPanel.Styles>
                        <Style Selector="TextBox.config-entry">
                            <Setter Property="Height" Value="20"/>
                            <Setter Property="MinHeight" Value="20"/>
                            <Setter Property="Padding" Value="5,1"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DockPanel.Styles>
                    <StackPanel DockPanel.Dock="Top" Spacing="6">
                    <TextBlock Text="Configuration" FontSize="15" FontWeight="SemiBold"/>

                    <TextBlock Text="CW Skimmer paths" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                    <Grid ColumnDefinitions="*,70" ColumnSpacing="6">
                        <TextBox Grid.Column="0"
                                 Classes="config-entry"
                                 Text="{Binding CwSkimmerExePath}"
                                 Watermark="Path to CwSkimmer.exe"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Width="70" Height="20"
                                FontSize="9" Padding="6,0"
                                Click="OnBrowseCwSkimmer"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,70" ColumnSpacing="6">
                        <TextBox Grid.Column="0"
                                 Classes="config-entry"
                                 Text="{Binding CwSkimmerIniPath}"
                                 Watermark="Path to cwskimmer.ini"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Width="70" Height="20"
                                FontSize="9" Padding="6,0"
                                Click="OnBrowseCwSkimmerIni"/>
                    </Grid>

                    <Separator Margin="0,4,0,0" Background="#DDD"/>
                    <Grid ColumnDefinitions="Auto,Auto,10,Auto,30,10,52,10,52,*" ColumnSpacing="3" RowDefinitions="Auto" Margin="0,0,0,2">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Spots" FontSize="11" FontWeight="SemiBold" Foreground="Gray" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding SpotForwardingEnabled}" Content="Enabled" FontSize="11" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Persist" FontSize="11" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="4"
                                 Classes="config-entry"
                                 Text="{Binding SpotLifetimeSeconds}"
                                 Width="30"
                                 MinWidth="30"
                                 MaxWidth="30"
                                 Padding="2,1"
                                 HorizontalAlignment="Left"/>

                        <Button Grid.Row="0" Grid.Column="6"
                                Classes="config-entry"
                                Width="52"
                                Height="20"
                                Padding="4,0"
                                Click="OnOpenSpotTextColorMenu">
                            <Grid ColumnDefinitions="Auto,4,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="Txt" FontSize="9" VerticalAlignment="Center"/>
                                <Border Grid.Column="2"
                                        Width="26"
                                        Height="11"
                                        Background="{Binding SpotSelectedColorOption.Hex}"
                                        BorderBrush="#666"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Grid.Row="0" Grid.Column="8"
                                Classes="config-entry"
                                Width="52"
                                Height="20"
                                Padding="4,0"
                                Click="OnOpenSpotBackgroundColorMenu">
                            <Grid ColumnDefinitions="Auto,4,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="Bg" FontSize="9" VerticalAlignment="Center"/>
                                <Border Grid.Column="2"
                                        Width="26"
                                        Height="11"
                                        Background="{Binding SpotSelectedBackgroundColorOption.Hex}"
                                        BorderBrush="#666"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>

                    <Separator Margin="0,4,0,0" Background="#DDD"/>
                    <TextBlock Text="Telnet cluster (from INI)" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                    </StackPanel>
                    <Border BorderBrush="#E3E6EA" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,0,2">
                        <TextBox Text="{Binding TelnetIniSummaryText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas"
                                 FontSize="10"
                                 Foreground="DarkSlateGray"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 TextWrapping="NoWrap"
                                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Border>

            </DockPanel>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <TextBlock Text="Logs" FontSize="10" FontWeight="SemiBold"/>
            </TabItem.Header>
            <Grid Margin="8" RowDefinitions="Auto,*" RowSpacing="6">
                <TextBlock Grid.Row="0" Text="Streamer status" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                <Border Grid.Row="1" BorderBrush="#E3E6EA" BorderThickness="1" CornerRadius="4" Padding="4">
                    <TextBox Text="{Binding FooterStatusText}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             FontSize="10"
                             Foreground="DarkOrange"
                             BorderThickness="0"
                             Background="Transparent"
                             TextWrapping="Wrap"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
